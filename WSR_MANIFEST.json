{
  "schemaVersion": 2,
  "packageName": "WSR-Core",
  "version": "1.0.1",
  "buildId": "WSR-CORE-1.0.1-RELEASE",
  "status": "Released",
  "createdAt": "2026-07-11T23:42:50+07:00",
  "canonicalLayout": ".agents",
  "compatibilityLayouts": [".codex"],
  "minimumPython": "3.8",
  "policySource": "GEMINI.md",
  "checksumsFile": "WSR_CHECKSUMS.json",
  "cleanWhitelist": [
    "DATA/",
    "ENGINE/",
    "Template/",
    "Tools/assets/",
    "DOCS/Planning/",
    ".git/",
    ".agents/",
    ".codex/"
  ],
  "packageExclusions": [
    "__pycache__/",
    "*.pyc",
    "desktop.ini",
    "*.zip",
    ".DS_Store",
    "Thumbs.db",
    "memory/",
    "metadata.json",
    "gitnexus/"
  ],
  "commands": {
    "audit": {
      "description": "Run static syntax, encoding, and integrity audits",
      "script": "scripts/wsr_audit.py",
      "options": {
        "--mode": "quick | deep",
        "--path": "Path to scan",
        "--json": "Output structured JSON report",
        "--changed": "Scan only files changed in git"
      }
    },
    "br": {
      "description": "Trigger brainstorm mode for discussions",
      "script": "global_workflows/br.md"
    },
    "pl": {
      "description": "Trigger planning workflow and create planning file",
      "script": "global_workflows/pl.md"
    },
    "clean": {
      "description": "Scan and remove temporary/unwanted files",
      "script": "scripts/wsr_clean.py",
      "options": {
        "--root": "Root path to scan",
        "--apply": "Execute deletions with token",
        "--json": "Output scan report as JSON",
        "--approval-token": "Approval token matching manifest buildId"
      }
    },
    "reload": {
      "description": "Reload policies, skills, and memory context",
      "script": "global_workflows/reload.md"
    },
    "wsr": {
      "description": "WSR packaging workflow",
      "script": "global_workflows/wsr.md"
    },
    "backup": {
      "description": "Create ZIP backup of workspace",
      "script": "global_workflows/backup.md"
    },
    "commit": {
      "description": "Commit changes via task-scoped logic",
      "script": "global_workflows/commit.md"
    }
  },
  "adapters": [
    "adapters/codex.json",
    "adapters/gemini.json",
    "adapters/claude.json",
    "adapters/cursor.json",
    "adapters/antigravity.json"
