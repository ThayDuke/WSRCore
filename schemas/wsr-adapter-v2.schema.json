{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WSRAdapterV2",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [
        2
      ]
    },
    "adapterId": {
      "type": "string"
    },
    "runtimeFamily": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean"
    },
    "supportLevel": {
      "type": "string",
      "enum": [
        "native",
        "workspace",
        "experimental",
        "unsupported"
      ]
    },
    "defaultTargetRoot": {
      "type": "string"
    },
    "targetRootEnvironmentVariable": {
      "type": "string"
    },
    "requiresExplicitTargetRoot": {
      "type": "boolean"
    },
    "logicalRoots": {
      "type": "object",
      "properties": {
        "policyRoot": {
          "type": "string"
        },
        "rulesRoot": {
          "type": "string"
        },
        "workflowsRoot": {
          "type": "string"
        },
        "skillsRoot": {
          "type": "string"
        },
        "scriptsRoot": {
          "type": "string"
        },
        "stateRoot": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "discoveryPrecedence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifactMappings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "artifactType": {
            "type": "string"
          },
          "artifactId": {
            "type": "string"
          },
          "logicalRoot": {
            "type": "string"
          },
          "relativePath": {
            "type": "string"
          }
        },
        "required": [
          "artifactType",
          "logicalRoot"
        ],
        "additionalProperties": false
      }
    },
    "routerContract": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "path"
      ],
      "additionalProperties": false
    },
    "activeMarkerContract": {
      "type": "object",
      "properties": {
        "required": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "required",
        "path"
      ],
      "additionalProperties": false
    },
    "unsupportedFeatures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "schemaVersion",
    "adapterId",
    "runtimeFamily",
    "enabled",
    "supportLevel",
    "defaultTargetRoot",
    "targetRootEnvironmentVariable",
    "requiresExplicitTargetRoot",
    "logicalRoots",
    "discoveryPrecedence",
    "artifactMappings",
    "routerContract",
    "activeMarkerContract",
    "unsupportedFeatures"
  ],
  "additionalProperties": false
}