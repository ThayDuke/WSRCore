{
  "schemaVersion": 2,
  "adapterId": "codex",
  "runtimeFamily": "codex",
  "enabled": true,
  "supportLevel": "native",
  "defaultTargetRoot": "~/.codex",
  "targetRootEnvironmentVariable": "CODEX_HOME",
  "requiresExplicitTargetRoot": false,
  "logicalRoots": {
    "policyRoot": ".",
    "rulesRoot": "rules",
    "workflowsRoot": "workflows",
    "skillsRoot": "skills",
    "scriptsRoot": "scripts",
    "stateRoot": "."
  },
  "discoveryPrecedence": [
    "AGENTS.md",
    ".codex/AGENTS.md",
    "~/.codex/AGENTS.md"
  ],
  "artifactMappings": [
    {
      "artifactType": "rule",
      "logicalRoot": "rulesRoot",
      "relativePath": "global_rules/AG_GLOBAL_RULES.md"
    },
    {
      "artifactType": "workflow",
      "logicalRoot": "workflowsRoot",
      "relativePath": "./"
    },
    {
      "artifactType": "skill",
      "logicalRoot": "skillsRoot",
      "relativePath": "./"
    },
    {
      "artifactType": "script",
      "logicalRoot": "scriptsRoot",
      "relativePath": "./"
    }
  ],
  "routerContract": {
    "type": "absolute",
    "path": "AGENTS.md"
  },
  "activeMarkerContract": {
    "required": true,
    "path": ".wsr-active.json"
  },
  "unsupportedFeatures": [
    "block-jit"
  ]
}