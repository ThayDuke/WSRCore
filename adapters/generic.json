{
  "schemaVersion": 2,
  "adapterId": "generic",
  "runtimeFamily": "generic",
  "enabled": true,
  "supportLevel": "workspace",
  "defaultTargetRoot": "",
  "targetRootEnvironmentVariable": "WSR_WORKSPACE_ROOT",
  "requiresExplicitTargetRoot": true,
  "logicalRoots": {
    "policyRoot": ".agents",
    "rulesRoot": ".agents/global_rules",
    "workflowsRoot": ".agents/global_workflows",
    "skillsRoot": ".agents/skills",
    "scriptsRoot": ".agents/scripts",
    "stateRoot": ".agents"
  },
  "discoveryPrecedence": [
    ".agents/AGENTS.md"
  ],
  "artifactMappings": [
    { "artifactType": "rule", "logicalRoot": "rulesRoot", "relativePath": "global_rules/AG_GLOBAL_RULES.md" },
    { "artifactType": "workflow", "logicalRoot": "workflowsRoot", "relativePath": "./" },
    { "artifactType": "skill", "logicalRoot": "skillsRoot", "relativePath": "./" },
    { "artifactType": "script", "logicalRoot": "scriptsRoot", "relativePath": "./" }
  ],
  "routerContract": {
    "type": "absolute",
    "path": ".agents/AGENTS.md"
  },
  "activeMarkerContract": {
    "required": true,
    "path": ".agents/.wsr-active.json"
  },
  "unsupportedFeatures": ["user-home-install"]
}
